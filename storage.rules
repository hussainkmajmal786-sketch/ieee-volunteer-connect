rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userProfilePath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function userProfileExists() {
      return isSignedIn() && firestore.exists(userProfilePath());
    }

    function userRole() {
      return firestore.get(
        userProfilePath()
      ).data.role;
    }

    function hasPrivilegedRole(role) {
      return role in ['admin', 'organizer', 'ADMIN', 'SUPER_ADMIN'];
    }

    function hasPrivilegedClaim() {
      return isSignedIn()
        && request.auth.token.role != null
        && hasPrivilegedRole(request.auth.token.role);
    }

    function canUploadManagedImages() {
      return hasPrivilegedClaim()
        || (userProfileExists() && hasPrivilegedRole(userRole()));
    }

    function isValidImageUpload() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType in [
          'image/jpeg',
          'image/png',
          'image/webp',
          'image/gif'
        ];
    }

    match /events/{imageFile} {
      allow read: if true;
      allow write: if canUploadManagedImages() && isValidImageUpload();
    }

    match /{folder}/{imageFile} {
      allow read: if true;
      allow write: if canUploadManagedImages()
        && (folder == 'volunteers' || folder == 'rewards' || folder == 'teams')
        && isValidImageUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
