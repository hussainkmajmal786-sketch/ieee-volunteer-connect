rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── EVENT BANNERS ──────────────────────────────────────
    // Public read, authenticated write (admins upload via dashboard)
    match /events/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── VOLUNTEER PHOTOS / REWARD IMAGES ───────────────────
    match /{folder}/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null
        && (folder == 'volunteers' || folder == 'rewards' || folder == 'teams')
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── DENY ALL OTHER PATHS ───────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
