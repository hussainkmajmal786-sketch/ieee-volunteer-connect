{
  "name": "ieee-volunteer-connect",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests --exclude tests/*.rules.test.js",
    "test:rules": "firebase emulators:exec --only firestore,storage \"vitest run tests/firestore.rules.test.js tests/storage.rules.test.js\"",
    "test:rules:firestore": "firebase emulators:exec --only firestore \"vitest run tests/firestore.rules.test.js\"",
    "test:rules:storage": "firebase emulators:exec --only firestore,storage \"vitest run tests/storage.rules.test.js\"",
    "test:load": "npx artillery run loadtest/config.yml"
  },
  "dependencies": {
    "@sentry/react": "^10.29.0",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-image-crop": "^11.0.10",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@smithy/config-resolver": "^4.5.3",
    "@smithy/middleware-retry": "^4.6.3",
    "@smithy/middleware-serde": "^4.3.3",
    "@smithy/node-config-provider": "^4.4.3",
    "@smithy/protocol-http": "^5.4.3",
    "@smithy/signature-v4": "^5.4.3",
    "@smithy/util-defaults-mode-node": "^4.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "artillery": "^2.0.31",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^13.35.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1",
    "vitest": "^4.1.6"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2"
  },
  "overrides": {
    "@tootallnate/once": "3.0.1",
    "tar": "7.5.15"
  }
}
